# Database Configuration
DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy

# Session Secret (used for cookie encryption)
SESSION_SECRET=dev-secret-change-in-production-abc123xyz789

# Replit Configuration (for local development)
REPLIT_DEPLOYMENT=false
REPL_ID=local-dev
REPL_OWNER=local-user
REPL_SLUG=careerconnect-local

# OpenID Client Configuration (Replit Auth)
REPLIT_CLIENT_ID=dummy-client-id-for-local-dev
REPLIT_CLIENT_SECRET=dummy-client-secret-for-local-dev

# Port
PORT=5000